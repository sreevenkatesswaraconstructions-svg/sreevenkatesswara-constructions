// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enum for payment types
enum PaymentType {
  Advance
  FirstInstallment
  SecondInstallment
  ThirdInstallment
  FinalPayment
  ExtraWork
  Refund
  Other
}

// User model for authentication and role-based access
model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("ADMIN")
  phone         String?
  emailVerified Boolean   @default(false)
  otpCode       String?
  otpExpiry     DateTime?
  profileImage  String?
  companyName   String?
  designation   String?
  lastLogin     DateTime?
  accountStatus String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

// OTPVerification model for storing OTPs during registration
model OTPVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  otpCode   String
  otpExpiry DateTime
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// Enquiry model for customer enquiries
model Enquiry {
  id           String   @id @default(cuid())
  customerName String
  phone        String
  email        String?
  service      String
  budget       String?
  location     String?
  message      String?
  status       String   @default("New")
  source       String   @default("Website")
  createdBy    String   @default("Website")
  isContacted  Boolean  @default(false)
  followUpDate DateTime?
  followUpTime String?
  followUpNotes String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  activities   EnquiryActivity[]
  quotations   Quotation[]
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerId   String?

  @@index([status])
  @@index([source])
  @@index([createdBy])
  @@index([createdAt])
  @@index([customerId])
}

model EnquiryActivity {
  id           String   @id @default(cuid())
  enquiry      Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)
  enquiryId    String
  activity     String
  performedBy  String   @default("System")
  createdAt    DateTime @default(now())

  @@index([enquiryId])
  @@index([createdAt])
}

model Customer {
  id         String      @id @default(cuid())
  name       String
  phone      String      @unique
  email      String?
  location   String?
  status     String      @default("Active")
  enquiryId  String?
  enquiries  Enquiry[]
  quotations Quotation[]
  contactHistory CustomerContactHistory[]
  projects   Project[]
  invoices   Invoice[]
  timeline   CustomerTimeline[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([phone])
  @@index([enquiryId])
}

model Invoice {
  id            String    @id @default(cuid())
  invoiceNumber String    @unique
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName  String?
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status        String    @default("Draft")
  issueDate     DateTime  @default(now())
  dueDate       DateTime?
  subtotal      Float     @default(0)
  discountPercent Float    @default(0)
  discountAmount Float     @default(0)
  taxPercent    Float     @default(0)
  taxAmount     Float     @default(0)
  totalAmount   Float     @default(0)
  notes         String?
  items         InvoiceItem[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([invoiceNumber])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId   String
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  amount      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([invoiceId])
}

model CustomerTimeline {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  eventType   String
  title       String
  description String?
  source      String   @default("SYSTEM")
  createdBy   String?

  createdAt   DateTime @default(now())

  @@index([customerId])
  @@index([createdAt])
}

// Contact history entries for customer communications and manual notes
model CustomerContactHistory {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  type       String
  title      String
  description String?
  createdBy  String?

  createdAt  DateTime @default(now())

  @@index([customerId])
  @@index([createdAt])
}

model Labour {
  id          String   @id @default(cuid())
  name        String
  phone       String
  role        String
  dailyWage   Float
  status      String   @default("ACTIVE")
  joiningDate DateTime @default(now())
  notes       String?
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([role])
  @@index([phone])
  @@index([projectId])
}

model Material {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materialName String
  category     String?
  quantity     Float
  unit         String?
  unitPrice    Float    @default(0)
  totalPrice   Float    @default(0)
  supplier     String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([projectId])
  @@index([materialName])
}

// Project model for project management
model Project {
  id               String    @id @default(cuid())
  title            String
  description      String?
  category         String?
  status           String    @default("Planning")
  projectType      String?
  siteAddress      String?
  startDate        DateTime?
  expectedEndDate  DateTime?
  estimatedBudget  String?
  projectManager   String?
  customerId       String?
  customer         Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  images String?
  videos String?

  location String?

  completionDate DateTime?
  clientName     String?

  featured Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  timelines ProjectTimeline[]
  documents ProjectDocument[]
  payments  ProjectPayment[]
  labours   Labour[]
  materials Material[]
  invoices  Invoice[]
  progressHistory ProjectProgress[]

  @@index([customerId])
  @@index([status])
}

model ProjectProgress {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  stage      String
  percentage Int
  notes      String?

  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([projectId])
  @@index([createdAt])
}

model ProjectPayment {
  id              String      @id @default(cuid())
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String
  paymentDate     DateTime
  amount          Float
  paymentMode     String
  paymentType     PaymentType @default(Other)
  referenceNumber String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([projectId])
  @@index([paymentDate])
}

model ProjectDocument {
  id           String   @id @default(cuid())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  fileName     String
  originalName String
  fileUrl      String
  fileType     String?
  category     String?
  fileSize     Int?
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@index([projectId])
  @@index([createdAt])
}

// ProjectTimeline model for project timelines/events
model ProjectTimeline {
  id          String   @id @default(cuid())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  title       String
  description String?
  type        String   @default("Other")
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
  @@index([createdAt])
}

// Blog model for CMS-style blog management
model Blog {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  author          String    @default("Admin")
  category        String
  tags            String?
  featuredImage   String?
  metaTitle       String?
  metaDescription String?
  published       Boolean   @default(false)
  featured        Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([published])
  @@index([category])
  @@index([featured])
}

// Service model for services management
model Service {
  id                  String   @id @default(cuid())
  serviceName         String
  slug                String   @unique
  shortDescription    String?
  detailedDescription String?
  image               String?
  status              String   @default("ACTIVE")
  featured            Boolean  @default(false)
  seoTitle            String?
  seoDescription      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([featured])
}

// Testimonial model for customer reviews management
model Testimonial {
  id               String   @id @default(cuid())
  customerName     String
  customerEmail    String?
  customerPhone    String?
  customerLocation String
  customerRole     String?
  reviewMessage    String
  rating           Int      @default(5)
  customerPhoto    String?
  status           String   @default("Pending")
  isFeatured       Boolean  @default(false)
  displayOrder     Int      @default(0)
  adminNotes       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([isFeatured])
  @@index([displayOrder])
  @@index([createdAt])
}

// Analytics model for visitor tracking
model Analytics {
  id     String   @id @default(cuid())
  page   String
  visits Int      @default(0)
  date   DateTime @default(now())

  @@index([page])
  @@index([date])
}

// Settings model for site configuration
model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

// EmailLog model for tracking email activity
model EmailLog {
  id        String   @id @default(cuid())
  toEmail   String
  subject   String
  type      String // 'customer_acknowledgement', 'admin_notification', 'otp', etc.
  status    String // 'sent', 'failed', 'pending'
  error     String?
  enquiryId String?
  metadata  String? // JSON string for additional data
  createdAt DateTime @default(now())

  @@index([toEmail])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

// Quotation model for admin quotations
model Quotation {
  id                String   @id @default(cuid())
  quotationNumber   String   @unique
  enquiryId         String?
  enquiry           Enquiry? @relation(fields: [enquiryId], references: [id], onDelete: SetNull)
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  customerName      String
  customerPhone     String
  customerEmail     String
  siteAddress       String
  city              String?
  state             String?
  pincode           String?
  referenceBy       String?
  projectName       String
  projectType       String
  projectLocation   String?
  plotArea          String?
  builtUpArea       String?
  floors            Int?
  estimatedDuration String?
  status            String   @default("Draft")
  services          String?
  boq               String?
  paymentSchedule   String?
  terms             String?
  notes             String?
  attachments       String?
  subtotal          Float?   @default(0)
  gstTotal          Float?   @default(0)
  discount          Float?   @default(0)
  grandTotal        Float?   @default(0)
  isDraft           Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Structured relations (new) — kept additive to avoid breaking existing JSON usage
  items           QuotationItem[]
  materials       QuotationMaterial[]
  paymentStages   QuotationPaymentStage[]
  warranties      QuotationWarranty[]
  termsList       QuotationTerm[]
  attachmentsList QuotationAttachment[]
  histories       QuotationHistory[]

  @@index([status])
  @@index([createdAt])
  @@index([enquiryId])
}

// Detailed items for BOQ (structured)
model QuotationItem {
  id          String    @id @default(cuid())
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  quotationId String
  sno         Int?
  description String
  quantity    Float     @default(0)
  unit        String?
  rate        Float     @default(0)
  gst         Float     @default(0)
  discount    Float     @default(0)
  amount      Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([quotationId])
}

model QuotationMaterial {
  id            String    @id @default(cuid())
  quotation     Quotation @relation(fields: [quotationId], references: [id])
  quotationId   String
  material      String
  brand         String?
  specification String?
  quantity      Float?    @default(0)
  unit          String?
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([quotationId])
}

model QuotationTerm {
  id          String    @id @default(cuid())
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  quotationId String
  order       Int?
  text        String
  createdAt   DateTime  @default(now())

  @@index([quotationId])
}

model QuotationAttachment {
  id           String    @id @default(cuid())
  quotation    Quotation @relation(fields: [quotationId], references: [id])
  quotationId  String
  fileName     String
  originalName String?
  fileUrl      String
  mimeType     String?
  fileSize     Int?
  createdAt    DateTime  @default(now())

  @@index([quotationId])
}

model QuotationPaymentStage {
  id          String    @id @default(cuid())
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  quotationId String
  order       Int?
  title       String
  percent     Float     @default(0)
  createdAt   DateTime  @default(now())

  @@index([quotationId])
}

model QuotationWarranty {
  id          String    @id @default(cuid())
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  quotationId String
  years       Int?
  description String
  createdAt   DateTime  @default(now())

  @@index([quotationId])
}

model QuotationHistory {
  id          String    @id @default(cuid())
  quotation   Quotation @relation(fields: [quotationId], references: [id])
  quotationId String
  adminName   String?
  action      String
  meta        String?
  ipAddress   String?
  createdAt   DateTime  @default(now())

  @@index([quotationId])
  @@index([action])
}

// Media model for file uploads
model Media {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  fileType     String // 'image' or 'video'
  mimeType     String
  fileSize     Int
  fileUrl      String
  uploadedAt   DateTime @default(now())

  @@index([fileType])
  @@index([uploadedAt])
}

// Notification model for admin notifications
model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String // 'success', 'warning', 'info', 'error'
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

// ActivityLog model for tracking admin actions
model ActivityLog {
  id        String   @id @default(cuid())
  adminName String
  action    String
  module    String
  ipAddress String?
  browser   String?
  createdAt DateTime @default(now())

  @@index([module])
  @@index([createdAt])
  @@index([adminName])
}
