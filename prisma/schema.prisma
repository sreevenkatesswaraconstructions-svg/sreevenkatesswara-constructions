generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("ADMIN")
  phone         String?
  emailVerified Boolean   @default(false)
  otpCode       String?
  otpExpiry     DateTime?
  profileImage  String?
  companyName   String?
  designation   String?
  lastLogin     DateTime?
  accountStatus String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
}

model OTPVerification {
  id        String   @id @default(cuid())
  email     String   @unique
  otpCode   String
  otpExpiry DateTime
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

model Enquiry {
  id            String            @id @default(cuid())
  customerName  String
  phone         String
  email         String?
  service       String
  budget        String?
  location      String?
  message       String?
  status        String            @default("New")
  isContacted   Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  createdBy     String            @default("Website")
  source        String            @default("Website")
  followUpDate  DateTime?
  followUpNotes String?
  followUpTime  String?
  customerId    String?
  customer      Customer?         @relation(fields: [customerId], references: [id])
  activities    EnquiryActivity[]
  quotations    Quotation[]

  @@index([status])
  @@index([source])
  @@index([createdBy])
  @@index([createdAt])
  @@index([customerId])
}

model EnquiryActivity {
  id          String   @id @default(cuid())
  enquiryId   String
  activity    String
  performedBy String   @default("System")
  createdAt   DateTime @default(now())
  enquiry     Enquiry  @relation(fields: [enquiryId], references: [id], onDelete: Cascade)

  @@index([enquiryId])
  @@index([createdAt])
}

model Customer {
  id                     String                   @id @default(cuid())
  name                   String
  phone                  String                   @unique
  email                  String?
  location               String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  enquiryId              String?
  status                 String                   @default("Active")
  CustomerContactHistory CustomerContactHistory[]
  timeline               CustomerTimeline[]
  enquiries              Enquiry[]
  invoices               Invoice[]
  projects               Project[]
  quotations             Quotation[]

  @@index([phone])
  @@index([enquiryId])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String        @unique
  customerId      String?
  customerName    String?
  projectId       String?
  status          String        @default("Draft")
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  subtotal        Float         @default(0)
  taxAmount       Float         @default(0)
  totalAmount     Float         @default(0)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  discountAmount  Float         @default(0)
  discountPercent Float         @default(0)
  taxPercent      Float         @default(0)
  customer        Customer?     @relation(fields: [customerId], references: [id])
  project         Project?      @relation(fields: [projectId], references: [id])
  items           InvoiceItem[]

  @@index([customerId])
  @@index([projectId])
  @@index([status])
  @@index([invoiceNumber])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  description String
  quantity    Float    @default(1)
  unitPrice   Float    @default(0)
  amount      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model CustomerTimeline {
  id          String   @id @default(cuid())
  customerId  String
  eventType   String
  title       String
  description String?
  source      String   @default("SYSTEM")
  createdBy   String?
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([createdAt])
}

model Labour {
  id          String   @id @default(cuid())
  name        String
  phone       String
  role        String
  dailyWage   Float
  status      String   @default("ACTIVE")
  joiningDate DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([role])
  @@index([phone])
  @@index([projectId])
}

model Material {
  id           String   @id @default(cuid())
  projectId    String
  materialName String
  category     String?
  quantity     Float
  unit         String?
  unitPrice    Float    @default(0)
  totalPrice   Float    @default(0)
  supplier     String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([materialName])
}

model Project {
  id              String            @id @default(cuid())
  title           String
  description     String?
  category        String?
  status          String            @default("Planning")
  images          String?
  videos          String?
  location        String?
  completionDate  DateTime?
  clientName      String?
  featured        Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  customerId      String?
  estimatedBudget String?
  expectedEndDate DateTime?
  projectManager  String?
  projectType     String?
  siteAddress     String?
  startDate       DateTime?
  invoices        Invoice[]
  labours         Labour[]
  materials       Material[]
  customer        Customer?         @relation(fields: [customerId], references: [id])
  documents       ProjectDocument[]
  payments        ProjectPayment[]
  progressHistory ProjectProgress[]
  timelines       ProjectTimeline[]

  @@index([customerId])
  @@index([status])
}

model ProjectProgress {
  id         String   @id @default(cuid())
  projectId  String
  stage      String
  percentage Int
  notes      String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

model ProjectPayment {
  id              String      @id @default(cuid())
  projectId       String
  paymentDate     DateTime
  amount          Float
  paymentMode     String
  referenceNumber String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  paymentType     PaymentType @default(Other)
  project         Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([paymentDate])
}

model ProjectDocument {
  id           String   @id @default(cuid())
  projectId    String
  fileName     String
  originalName String
  fileUrl      String
  fileType     String?
  fileSize     Int?
  uploadedBy   String?
  createdAt    DateTime @default(now())
  category     String?
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

model ProjectTimeline {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  type        String   @default("Other")
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([createdAt])
}

model Blog {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String
  excerpt         String?
  author          String    @default("Admin")
  category        String
  tags            String?
  featuredImage   String?
  metaTitle       String?
  metaDescription String?
  published       Boolean   @default(false)
  featured        Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([published])
  @@index([category])
  @@index([featured])
}

model Service {
  id                  String   @id @default(cuid())
  serviceName         String
  slug                String   @unique
  shortDescription    String?
  detailedDescription String?
  image               String?
  status              String   @default("ACTIVE")
  featured            Boolean  @default(false)
  seoTitle            String?
  seoDescription      String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([slug])
  @@index([status])
  @@index([featured])
}

model Testimonial {
  id               String   @id @default(cuid())
  customerName     String
  customerEmail    String?
  customerPhone    String?
  customerLocation String
  customerRole     String?
  reviewMessage    String
  rating           Int      @default(5)
  customerPhoto    String?
  status           String   @default("Pending")
  isFeatured       Boolean  @default(false)
  displayOrder     Int      @default(0)
  adminNotes       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([isFeatured])
  @@index([displayOrder])
  @@index([createdAt])
}

model Analytics {
  id     String   @id @default(cuid())
  page   String
  visits Int      @default(0)
  date   DateTime @default(now())

  @@index([page])
  @@index([date])
}

model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model EmailLog {
  id        String   @id @default(cuid())
  toEmail   String
  subject   String
  type      String
  status    String
  error     String?
  enquiryId String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([toEmail])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model Quotation {
  id                String                  @id @default(cuid())
  quotationNumber   String                  @unique
  customerName      String
  customerPhone     String
  customerEmail     String
  siteAddress       String
  city              String?
  state             String?
  pincode           String?
  referenceBy       String?
  projectName       String
  projectType       String
  projectLocation   String?
  plotArea          String?
  builtUpArea       String?
  floors            Int?
  estimatedDuration String?
  status            String                  @default("Draft")
  services          String?
  boq               String?
  paymentSchedule   String?
  terms             String?
  notes             String?
  attachments       String?
  subtotal          Float?                  @default(0)
  gstTotal          Float?                  @default(0)
  discount          Float?                  @default(0)
  grandTotal        Float?                  @default(0)
  isDraft           Boolean                 @default(true)
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  enquiryId         String?
  customerId        String?
  customer          Customer?               @relation(fields: [customerId], references: [id])
  enquiry           Enquiry?                @relation(fields: [enquiryId], references: [id])
  attachmentsList   QuotationAttachment[]
  histories         QuotationHistory[]
  items             QuotationItem[]
  materials         QuotationMaterial[]
  paymentStages     QuotationPaymentStage[]
  termsList         QuotationTerm[]
  warranties        QuotationWarranty[]

  @@index([status])
  @@index([createdAt])
  @@index([enquiryId])
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  sno         Int?
  description String
  quantity    Float     @default(0)
  unit        String?
  rate        Float     @default(0)
  gst         Float     @default(0)
  discount    Float     @default(0)
  amount      Float     @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  quotation   Quotation @relation(fields: [quotationId], references: [id])

  @@index([quotationId])
}

model QuotationMaterial {
  id            String    @id @default(cuid())
  quotationId   String
  material      String
  brand         String?
  specification String?
  quantity      Float?    @default(0)
  unit          String?
  remarks       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  quotation     Quotation @relation(fields: [quotationId], references: [id])

  @@index([quotationId])
}

model QuotationTerm {
  id          String    @id @default(cuid())
  quotationId String
  order       Int?
  text        String
  createdAt   DateTime  @default(now())
  quotation   Quotation @relation(fields: [quotationId], references: [id])

  @@index([quotationId])
}

model QuotationAttachment {
  id           String    @id @default(cuid())
  quotationId  String
  fileName     String
  originalName String?
  fileUrl      String
  mimeType     String?
  fileSize     Int?
  createdAt    DateTime  @default(now())
  quotation    Quotation @relation(fields: [quotationId], references: [id])

  @@index([quotationId])
}

model QuotationPaymentStage {
  id          String    @id @default(cuid())
  quotationId String
  order       Int?
  title       String
  percent     Float     @default(0)
  createdAt   DateTime  @default(now())
  quotation   Quotation @relation(fields: [quotationId], references: [id])

  @@index([quotationId])
}

model QuotationWarranty {
  id          String    @id @default(cuid())
  quotationId String
  years       Int?
  description String
  createdAt   DateTime  @default(now())
  quotation   Quotation @relation(fields: [quotationId], references: [id])

  @@index([quotationId])
}

model QuotationHistory {
  id          String    @id @default(cuid())
  quotationId String
  adminName   String?
  action      String
  meta        String?
  ipAddress   String?
  createdAt   DateTime  @default(now())
  quotation   Quotation @relation(fields: [quotationId], references: [id])

  @@index([quotationId])
  @@index([action])
}

model Media {
  id           String   @id @default(cuid())
  fileName     String
  originalName String
  fileType     String
  mimeType     String
  fileSize     Int
  fileUrl      String
  uploadedAt   DateTime @default(now())

  @@index([fileType])
  @@index([uploadedAt])
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  adminName String
  action    String
  module    String
  ipAddress String?
  browser   String?
  createdAt DateTime @default(now())

  @@index([module])
  @@index([createdAt])
  @@index([adminName])
}

model CustomerContactHistory {
  id          String   @id
  customerId  String
  type        String
  title       String
  description String?
  createdBy   String?
  createdAt   DateTime @default(now())
  Customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([customerId])
}

enum PaymentType {
  Advance
  FirstInstallment
  SecondInstallment
  ThirdInstallment
  FinalPayment
  ExtraWork
  Refund
  Other
}
